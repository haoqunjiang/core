{
  "name": "@vue/lightningcss-lexer",
  "version": "3.5.32",
  "description": "Lightning CSS-compatible selector and source lexer helpers",
  "main": "dist/lightningcss-lexer.cjs.js",
  "module": "dist/lightningcss-lexer.esm-bundler.js",
  "types": "dist/lightningcss-lexer.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/lightningcss-lexer.d.ts",
      "node": "./dist/lightningcss-lexer.cjs.js",
      "module": "./dist/lightningcss-lexer.esm-bundler.js",
      "import": "./dist/lightningcss-lexer.esm-bundler.js",
      "require": "./dist/lightningcss-lexer.cjs.js"
    },
    "./*": "./*"
  },
  "sideEffects": false,
  "buildOptions": {
    "name": "VueLightningCssLexer",
    "formats": [
      "esm-bundler",
      "cjs"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vuejs/core.git",
    "directory": "packages/lightningcss-lexer"
  },
  "keywords": [
    "vue",
    "css",
    "lightningcss"
  ],
  "author": "Evan You",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/vuejs/core/issues"
  },
  "homepage": "https://github.com/vuejs/core/tree/main/packages/lightningcss-lexer#readme",
  "peerDependencies": {
    "lightningcss": "^1.32.0"
  },
  "peerDependenciesMeta": {
    "lightningcss": {
      "optional": true
    }
  },
  "devDependencies": {
    "lightningcss": "^1.32.0"
  }
}
